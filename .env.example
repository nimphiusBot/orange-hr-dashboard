# Linear.app Integration
# Get API key from Linear → Settings → API
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxx

# Linear Webhook Secret
# Get from Linear → Settings → Webhooks
LINEAR_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# Orange HR Dashboard
PORT=3003
WS_PORT=3004
NODE_ENV=development

# For production:
# NODE_ENV=production
# DATABASE_URL=postgresql://user:password@localhost:5432/orange_hr