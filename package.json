{
  "name": "storyhouse-hr-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Elite HR Dashboard for StoryHouse - Beautiful productivity visualization",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "dev:backend": "tsx watch src/backend/index.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:backend\"",
    "api": "tsx src/backend/index.ts",
    "start": "concurrently \"npm run dev\" \"npm run api\"",
    "setup-linear": "node scripts/setup-linear-api.js",
    "test-linear": "node scripts/test-linear-webhook.js",
    "railway": "tsx src/backend/index.ts"
  },
